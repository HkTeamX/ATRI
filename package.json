{
  "type": "module",
  "scripts": {
    "lint": "bun run --filter './{packages,plugins,libs}/*' --filter '[lint]' lint",
    "typecheck": "bun run --filter './{packages,plugins,libs}/*' --filter '[typecheck]' typecheck",
    "clean": "rm -rf node_modules && bun install"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^8.0.0",
    "@types/bun": "^1.3.11",
    "eslint": "^10.1.0",
    "jiti": "^2.6.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2"
  },
  "workspaces": [
    "packages/*",
    "plugins/*",
    "libs/*"
  ]
}
