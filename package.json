{
  "type": "module",
  "scripts": {
    "lint": "bun run --filter './{packages,plugins}/*' --filter '[lint]' lint",
    "build": "bun run --filter '@atri-bot/core' build",
    "typecheck": "bun run --filter './{packages,plugins}/*' --filter '[typecheck]' typecheck",
    "clean": "rm -rf node_modules && bun install"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@types/bun": "^1.3.11",
    "eslint": "^10.1.0",
    "jiti": "^2.6.1",
    "tsdown": "^0.21.4",
    "typescript": "^5.9.3"
  },
  "workspaces": [
    "packages/*",
    "plugins/*"
  ]
}
